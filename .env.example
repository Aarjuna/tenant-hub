# Postgres connection string (Neon in production; local Docker Postgres in dev)
DATABASE_URL="postgresql://user:password@localhost:5432/tenanthub?schema=public"

# Session / auth
# Generate with: openssl rand -base64 32
SESSION_SECRET="replace-with-a-random-32+-character-secret"
ADMIN_EMAIL="you@example.com"
# bcrypt hash of your admin password. Generate with:
#   node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
# IMPORTANT: escape every '$' in the hash as '\$' — Next.js expands unescaped $VAR
# patterns in .env files, which corrupts bcrypt hashes.
ADMIN_PASSWORD_HASH=""

# Cron (must match the value Vercel sends as `Authorization: Bearer <value>`
# when you set CRON_SECRET in your Vercel project's env vars)
CRON_SECRET="replace-with-a-random-secret"

# Email (Resend) — https://resend.com
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""

# SMS (Twilio) — https://twilio.com, phone number must be in E.164 format
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""
